# ============================================
# Get from: https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=6Lf4r9MsAAAAALI4wjU9odDJXCI3lKclw6wOZKSa

# For Edge Functions (server-side only)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ============================================
# PAYMENT GATEWAYS
# ============================================

# PayPal (International payments)
# Get from: https://developer.paypal.com/dashboard/applications
VITE_PAYPAL_CLIENT_ID=your_paypal_client_id
# ⚠️  NEVER expose PayPal secret in frontend env vars.
# Store PAYPAL_CLIENT_SECRET only in Supabase Edge Function secrets:
#   supabase secrets set PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
VITE_PAYPAL_SETTLEMENT_CURRENCY=EUR
PAYPAL_SETTLEMENT_CURRENCY=EUR
PAYPAL_MAD_EXCHANGE_RATE=0.092

# CMI (Moroccan payment gateway)
# Get from: https://www.cmi.co.ma
VITE_CMI_MERCHANT_ID=your_cmi_merchant_id
# ⚠️  CMI store key must NOT use VITE_ prefix — set it via Supabase Edge Function secrets:
#   supabase secrets set CMI_STORE_KEY=your_store_key
CMI_STORE_KEY=your_cmi_store_key
# ⚠️  Merchant key for server-side signing/verification in Edge Functions
CMI_MERCHANT_ID=your_cmi_merchant_id

# Payment mode: test | production
VITE_PAYMENT_MODE=test

# ============================================
# EMAIL SERVICE
# ============================================

# Enable email service: true | false
VITE_EMAIL_ENABLED=true

# Email sender
VITE_EMAIL_FROM=noreply@qotoof.ma

# Option 1: Resend (Recommended)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ============================================
# ERROR MONITORING
# ============================================

# Sentry (Error tracking)
# Get from: https://sentry.io/settings/account/api-keys/
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Google Maps (required for delivery maps and checkout distance estimates)
# Get from: https://console.cloud.google.com/google/maps-apis
VITE_GOOGLE_MAPS_KEY=your-google-maps-browser-key

# ============================================
# ANALYTICS
# ============================================

# Google Analytics
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Privacy-friendly analytics (e.g. Plausible / Umami)
VITE_ANALYTICS_DOMAIN=analytics.yourdomain.com
VITE_ANALYTICS_SITE_ID=yourdomain.com

# ============================================
# FILE STORAGE
# ============================================

# Supabase Storage (configured in dashboard)

# ============================================
# SECURITY
# ============================================

# Allowed origins for Edge Function CORS (comma-separated, no wildcards in production)
# Set this secret in the Supabase dashboard → Edge Functions → Secrets:
#   supabase secrets set ALLOWED_ORIGINS=https://greenmarket-marketplace.web.app,https://qotoof.ma
# For local development only you may set ALLOWED_ORIGINS=* (never commit this value)
ALLOWED_ORIGINS=

# ============================================
# APP CONFIGURATION
# ============================================

# App name and URL
VITE_APP_NAME=Qotoof
VITE_APP_URL=https://qotoof.ma
VITE_SUPPORT_EMAIL=Qotoof273@gmail.com
VITE_SUPPORT_PHONE=+212674841248

# Platform commission rate (percentage)
VITE_COMMISSION_RATE=0.03
VITE_DELIVERY_BASE_FEE=10
VITE_DELIVERY_PER_KM_FEE=5
PLATFORM_COMMISSION_RATE=0.03

# ============================================
# DEVELOPMENT ONLY
# ============================================

# ============================================
# NOTES
# ============================================
# 
# Setup Checklist:
# □ Supabase project created
# □ Database tables migrated
# □ Realtime enabled for required tables
# □ Storage buckets created
# □ Edge functions deployed (see below)
# □ Stripe account created (if using)
# □ CMI merchant account configured
# □ Bank transfer details configured
# □ Email service configured (Resend recommended)
# □ Sentry project created (optional)
# □ Domain configured (optional)
#
# Edge Functions to Deploy:
# supabase functions deploy create-payment-intent --no-verify-jwt
# supabase functions deploy refund-payment --no-verify-jwt
# supabase functions deploy stripe-checkout --no-verify-jwt
# supabase functions deploy stripe-webhook --no-verify-jwt
# supabase functions deploy create-cmi-session --no-verify-jwt
# supabase functions deploy verify-cmi-callback --no-verify-jwt
# supabase functions deploy refund-cmi-payment --no-verify-jwt
# supabase functions deploy confirm-bank-transfer --no-verify-jwt
# supabase functions deploy send-email --no-verify-jwt
#
# Deployment Commands:
# npm run build          - Build for production
# npm run preview        - Preview production build
# npm run deploy         - Deploy to Firebase Hosting
# supabase functions deploy - Deploy all Edge Functions
#
# Important URLs:
# Supabase: https://app.supabase.com
# Stripe: https://dashboard.stripe.com
# Resend: https://resend.com
# Sentry: https://sentry.io
# Firebase: https://console.firebase.google.com
#
