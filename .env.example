# QOTOOF Environment Template (safe for Git)
# Copy to .env for local development. Never commit real secrets.

# -----------------------------
# Public frontend variables (Vite)
# -----------------------------
VITE_APP_NAME=Qotoof
VITE_APP_VERSION=1.0.0
VITE_APP_URL=https://greenmarket-marketplace.web.app
VITE_SUPPORT_EMAIL=support@greenmarket-marketplace.web.app
VITE_SUPPORT_PHONE=+212600000000

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_KEY_HERE

VITE_PAYMENT_MODE=production
VITE_PAYPAL_CLIENT_ID=PASTE_LIVE_PAYPAL_CLIENT_ID_HERE
VITE_PAYPAL_SETTLEMENT_CURRENCY=EUR

VITE_STRIPE_PUBLISHABLE_KEY=PASTE_STRIPE_PUBLISHABLE_KEY_HERE

VITE_RECAPTCHA_SITE_KEY=PASTE_RECAPTCHA_SITE_KEY_HERE
VITE_SENTRY_DSN=PASTE_SENTRY_DSN_HERE

VITE_FIREBASE_API_KEY=PASTE_FIREBASE_API_KEY_HERE
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=PASTE_FIREBASE_MESSAGING_SENDER_ID_HERE
VITE_FIREBASE_APP_ID=PASTE_FIREBASE_APP_ID_HERE
VITE_GA_ID=G-PASTE_GA_ID_HERE

VITE_API_URL=https://api.greenmarket-marketplace.web.app
VITE_COMMISSION_RATE=0.03
VITE_DELIVERY_BASE_FEE=10
VITE_DELIVERY_PER_KM_FEE=5

# -----------------------------
# Server-side secrets (DO NOT keep in frontend env files)
# Set these in Supabase Edge Function secrets instead:
# supabase secrets set SUPABASE_URL="..."
# supabase secrets set SUPABASE_ANON_KEY="..."
# supabase secrets set SUPABASE_SERVICE_ROLE_KEY="..."
# supabase secrets set TOTP_SECRET_KEY="32+ char random string used to encrypt TOTP secrets"
# New Edge Functions requiring secrets: sign-out, change-password, verify-mfa, enable-mfa
# supabase secrets set PAYPAL_CLIENT_SECRET="..."
# supabase secrets set RESEND_API_KEY="..."
# supabase secrets set GOOGLE_CLIENT_SECRET="..."
# supabase secrets set CMI_STORE_KEY="..."
# -----------------------------
# SUPABASE_SERVICE_ROLE_KEY=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_WEBHOOK_ID=
# RESEND_API_KEY=
# GOOGLE_CLIENT_SECRET=
# CMI_STORE_KEY=
# CMI_MERCHANT_ID=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=
